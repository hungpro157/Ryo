{
  "name": "ryo-discord-bot-pc",
  "version": "4.0.0-pc",
  "description": "Ryo Discord AI bot for Windows PC with Ollama, Qwen and LanceDB RAG",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "test:behavior": "node --test test/behavior.test.js test/routing.test.js",
    "test:integration": "node --test test/routing.test.js test/youtube.test.js",
    "check": "node scripts/check.js",
    "check:imports": "node scripts/check-imports.js",
    "validate:config": "node scripts/validate-config.js",
    "db:reset": "node scripts/reset-db.js"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.22.3",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "lru-cache": "^10.2.0",
    "uuid": "^11.1.0"
  }
}
