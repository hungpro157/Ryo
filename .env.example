# ════════════════════════════════════════════
#         Ryo Bot — Environment Config
# ════════════════════════════════════════════

# [BẮT BUỘC] Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# [BẮT BUỘC] OpenAI API Key
OPENAI_API_KEY=sk-your_openai_key_here

# [TÙY CHỌN] Model OpenAI
# gpt-4o-mini = rẻ + nhanh | gpt-4o = thông minh hơn
OPENAI_MODEL=gpt-4o-mini

# [TÙY CHỌN] Discord User ID của bạn — CHỈ dùng làm fallback khi chat qua DM
# (DM không có "server" nên Ryo không tự detect được owner như trong server thường)
# Trong server, Ryo TỰ NHẬN BIẾT owner/admin/mod qua Discord API, không cần set gì cả
# Cách lấy: Bật Developer Mode trong Discord Settings → chuột phải vào tên mình → Copy User ID
OWNER_ID=your_discord_user_id_here

# [TÙY CHỌN] Channel ID để Ryo tự nhắn khi không có ai chat 1-2 ngày
# Cách lấy: chuột phải vào channel → Copy Channel ID
# Bỏ trống nếu không muốn dùng tính năng này
IDLE_CHANNEL_ID=your_channel_id_here
LLAMA_API_KEY=
LLAMA_BASE_URL=
LLAMA_MODEL=